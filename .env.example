# =============================================================================
# AgroOps — Variables de entorno
# Copiar a .env.local y rellenar con valores reales. NO commitear .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://agroops:agroops_dev@localhost:5432/agroops
# En producción: connection string del servidor único productivo

# -----------------------------------------------------------------------------
# Redis (sesiones Auth.js)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth.js v5
# -----------------------------------------------------------------------------
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# En producción: AUTH_URL=https://agroops.agrom.es

# -----------------------------------------------------------------------------
# Integraciones externas
# -----------------------------------------------------------------------------

# AEMET OpenData (https://opendata.aemet.es/)
AEMET_API_KEY=

# ENAIRE NOTAM feed
ENAIRE_NOTAM_FEED=https://aip.enaire.es/notam

# DroneHub API (v1.1+, opcional en v1)
DRONEHUB_API_KEY=
DRONEHUB_BASE_URL=https://api.dronehub.systemrapid.io

# Holded API (facturación)
HOLDED_API_KEY=
HOLDED_BASE_URL=https://api.holded.com/api/invoicing/v1

# -----------------------------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------------------------

# Telegram (healthcheck + alertas)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SA99 InfraService (registro post-deploy)
SA99_REGISTRATION_KEY=
SA99_BASE_URL=https://sa99.systemrapid.io

# -----------------------------------------------------------------------------
# Backups (S3-compatible, p.ej. Backblaze B2 o Hetzner Storage Box)
# -----------------------------------------------------------------------------
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=agroops-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_GPG_RECIPIENT=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=AgroOps
NEXT_PUBLIC_APP_URL=http://localhost:3000
