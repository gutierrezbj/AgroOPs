# =============================================================================
# AgroOps — .env.production.example
# Plantilla para el VPS Hostinger. Copiar a /opt/agroops/.env.production
# y rellenar con valores REALES. NUNCA commitear el .env.production.
#
# Generar AUTH_SECRET y POSTGRES_PASSWORD frescos para producción:
#   openssl rand -base64 32      → AUTH_SECRET
#   openssl rand -base64 24      → POSTGRES_PASSWORD
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres + Redis (los servicios docker-compose.prod.yml los crean)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=__GENERAR_CON_openssl_rand_base64_24__

# -----------------------------------------------------------------------------
# Auth.js v5
# -----------------------------------------------------------------------------
AUTH_SECRET=__GENERAR_CON_openssl_rand_base64_32__
AUTH_URL=https://agroops.systemrapid.io

# -----------------------------------------------------------------------------
# Integraciones reales (activar HU-12 ENAIRE y HU-13 AEMET)
# -----------------------------------------------------------------------------

# AEMET OpenData — registrar cuenta en https://opendata.aemet.es/
# Sin esta key, captureWeatherForCoordinates() devuelve stub.
AEMET_API_KEY=__PEGAR_API_KEY_AEMET__

# ENAIRE NOTAM feed (AIXM XML real)
# Sin URL, fetchActiveNotams() devuelve FeatureCollection vacía con source=enaire-stub.
ENAIRE_NOTAM_FEED=__URL_FEED_ENAIRE_AIXM__

# -----------------------------------------------------------------------------
# Facturación — v1.0 MODO MANUAL (decisión JuanCho 12-may-2026)
# AgroM emite facturas en Holded fuera del sistema. Cuando se decida
# activar la integración cambiar a 'holded' y rellenar HOLDED_API_KEY.
# -----------------------------------------------------------------------------
AGROOPS_INVOICING_MODE=manual
HOLDED_API_KEY=
AGROOPS_PRICE_PER_HA_EUR=25.00
AGROOPS_INVOICE_VAT_PCT=21

# -----------------------------------------------------------------------------
# Observabilidad — Telegram alerts (deploy + backup + healthcheck)
# Crear bot en @BotFather, conseguir chat_id con @userinfobot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=__BOT_TOKEN_AGROOPS_ALERTS__
TELEGRAM_CHAT_ID=__TU_CHAT_ID__

# -----------------------------------------------------------------------------
# Backup S3-compatible (Backblaze B2 o Hetzner Storage Box)
# Si vacío, scripts/backup.sh solo guarda local en /opt/agroops/storage/backups
# -----------------------------------------------------------------------------
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=agroops-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_GPG_RECIPIENT=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=AgroOps
NEXT_PUBLIC_APP_URL=https://agroops.systemrapid.io

# Versión: el deploy.sh inyecta el sha del commit. Aquí solo placeholder.
AGROOPS_VERSION=prod
